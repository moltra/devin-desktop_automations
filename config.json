{
  "version": 1,
  "mcpServers": {
    "github-mcp-server": {
      "url": "https://api.githubcopilot.com/mcp",
      "registry": "devin/github-mcp-server"
    },
    "git": {
      "command": "docker",
      "args": ["run", "-i", "--rm", "mcp/git"],
      "registry": "devin/git"
    },
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem"],
      "env": {
        "FILESYSTEM_PATHS": "/mnt/samsungssd/docker/"
      },
      "registry": "devin/filesystem"
    },
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "registry": "devin/memory"
    },
    "deepwiki": {
      "url": "https://mcp.deepwiki.com/mcp",
      "registry": "devin/deepwiki"
    },
    "mcp-playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"],
      "registry": "devin/mcp-playwright"
    },
    "redis": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-redis"],
      "env": {
        "REDIS_URL": "http://redis"
      }
    }
  },
  "permissions": {
    "allow": [
      "mcp__deepwiki__*",
      "Fetch(domain:raw.githubusercontent.com)",
      "Write(/mnt/samsungssd/docker)",
      "Fetch(domain:hub.docker.com)",
      "Fetch(domain:github.com)",
      "mcp__mcp-playwright__*",
      "Write(/mnt/samsungssd/repo/alltalk_tts)",
      "Read(~/.devin-server)",
      "Write(/tmp)",
      "mcp__github-mcp-server__*",
      "Fetch(domain:discuss.streamlit.io)",
      "Write(~/.config/devin/agents/streamlit-expert)",
      "Write(~/.config/devin/agents/redis-engineer)",
      "Write(~/.config/devin/agents/ollama-specialist)",
      "Write(~/.config/devin/agents/video-pipeline-reviewer)",
      "Write(~/.config/devin/agents/coordinator)",
      "Write(~/.config/devin/agents/python-reviewer)",
      "Write(~/.config/devin/agents/testing-guardian)",
      "Write(~/.config/devin/agents/security-auditor)",
      "Write(~/.config/devin/scripts)",
      "Write(~/.config/devin/skills/redis-resilience)",
      "Write(~/.config/devin/skills/ollama-testing)"
    ]
  }
}